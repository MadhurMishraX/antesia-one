# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPABASE_URL: Your Supabase project URL.
VITE_SUPABASE_URL="https://your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase project anonymous key.
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Admin Credentials
VITE_ADMIN_PASSWORD="your-strong-admin-password"
VITE_ADMIN_PIN="123456"

# Deployment Configuration
# Set to "true" to switch the app to the deployment database
VITE_USE_DEPLOYMENT_CONFIG="false"

# Deployment Supabase
VITE_DEPLOY_SUPABASE_URL=""
VITE_DEPLOY_SUPABASE_ANON_KEY=""

# Deployment Admin Credentials
VITE_DEPLOY_ADMIN_PASSWORD=""
VITE_DEPLOY_ADMIN_PIN=""

# Deployment Database Master Password
DEPLOYMENT_DATABASE_PASSWORD=""
